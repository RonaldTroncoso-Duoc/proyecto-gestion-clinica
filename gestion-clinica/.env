# ============================================================
# Variables de entorno - Proyecto Gestión Clínica
# Usadas por Docker Compose en la siguiente etapa.
# ============================================================

# MySQL
MYSQL_ROOT_PASSWORD=root
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_HOST=mysql
MYSQL_PORT=3306

# Bases de datos por microservicio
DB_AUTH=db_auth
DB_PACIENTES=db_pacientes
DB_MEDICOS=db_medicos
DB_CITAS=db_citas
DB_ESPECIALIDADES=db_especialidades
DB_HORARIOS=db_horarios
DB_FICHAS_CLINICAS=db_fichas_clinicas
DB_RECETAS=db_recetas
DB_PAGOS=db_pagos
DB_NOTIFICACIONES=db_notificaciones

# Eureka
EUREKA_CLIENT_SERVICEURL_DEFAULTZONE=http://eureka-server:8761/eureka/

# JWT compartido por ms-auth y api-gateway
JWT_SECRET=EstaEsUnaLlaveMuySecretaYQueDebeSerLargaParaQueFuncione12345